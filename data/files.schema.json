{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Medical Output Hub file index",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "course",
      "category",
      "title",
      "type",
      "date",
      "path",
      "source",
      "tags",
      "description"
    ],
    "properties": {
      "note_id": {
        "type": "string",
        "description": "Stable shared id for multiple downloadable formats of the same note."
      },
      "course": {
        "type": "string"
      },
      "category": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "title": {
        "type": "string"
      },
      "type": {
        "type": "string"
      },
      "date": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "path": {
        "type": "string",
        "pattern": "^files/.+"
      },
      "source": {
        "type": "string"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "description": {
        "type": "string"
      },
      "kind": {
        "type": "string",
        "enum": ["collection"],
        "description": "Optional record kind. Use collection for a grouped set of chapter files."
      },
      "items": {
        "type": "array",
        "description": "Chapter or child files for collection records.",
        "items": {
          "type": "object",
          "required": ["title"],
          "oneOf": [
            {
              "required": ["type", "path"]
            },
            {
              "required": ["files"]
            }
          ],
          "properties": {
            "title": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "path": {
              "type": "string",
              "pattern": "^files/.+"
            },
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "path"],
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string",
                    "pattern": "^files/.+"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
